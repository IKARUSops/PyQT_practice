    <property name="styleSheet">
     <string notr="true">QGroupBox {
    background-color: rgba(255, 255, 255, 30); /* Very transparent white */
    border: 1px solid rgba(255, 255, 255, 50); /* Subtle light border */
    border-radius: 15px; /* Rounded corners are essential for &quot;modern&quot; */
    margin-top: 20px;
    backdrop-filter: blur(10px); /* Note: Works in some Qt versions, but rgba is safer */
}

QGroupBox::title {
    color: white;
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 3px;
}

QPushButton {
    background-color: rgba(255, 255, 255, 80);
    color: white;
    border: 1px solid rgba(255, 255, 255, 95);
    border-radius: 10px;
    padding: 10px;
    font-family: &quot;Segoe UI&quot;, sans-serif; /* Clean font */
    font-size: 14px;
}

QPushButton:hover {
    background-color: rgba(255, 255, 255, 50); /* Brightens when hovering */
    border: 1px solid white;
}

QPushButton:pressed {
    background-color: rgba(255, 255, 255, 20); /* Darkens when clicked */
}</string>
