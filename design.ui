    background-color: rgba(0, 0, 0, 70); 
}
QLabel {
    color: rgba(0, 0, 0, 230); /* Off-white for better eyes */
    font-family: &quot;Ubuntu Mono&quot;;
}
QCheckBox {
    color: white;
}
QCheckBox::indicator {
    width: 15px;
    height: 15px;
    border-radius: 3px;
    border: 1px solid white;
    background-color: rgba(255, 255, 255, 20);
}
QCheckBox::indicator:checked {
    background-color: #4CAF50; /* A nice &quot;Linux green&quot; to match the leaf */
}</string>
